# Encryption – required (auto-generated on first run if not set)
# Master key for encrypting ASC credentials and AI API keys. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=

# Session – required (auto-generated on first run if not set)
# Random string for session encryption (32+ chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Database – optional (defaults to ./data/itsyship.db)
# DATABASE_PATH=/data/itsyship.db

# Port – optional (defaults to 3000)
# PORT=3000
